# DOCKER MYSQL CONFIGURATION
MYSQL_DATABASE=doecerto_development
MYSQL_PASSWORD=doecerto_development
MYSQL_ROOT_PASSWORD=doecerto_development

# =========================
# Banco de Dados
# =========================
DATABASE_URL="mysql://root:senha_root@localhost:3306/doecerto"   # URL de conexão do banco de dados

# =========================
# Configuração da Aplicação
# =========================
PORT=3001                      # Porta em que a API irá rodar
NODE_ENV=development           # Ambiente: development, production, test
APP_URL=http://localhost:3001  # URL base da aplicação (opcional)

# =========================
# CORS / Frontend
# =========================
FRONTEND_URL=http://localhost:3000   # URL do frontend permitido no CORS

# =========================
# Autenticação (JWT)
# =========================
JWT_SECRET=sua_chave_secreta_super_segura_aqui_123456   # Chave secreta JWT
JWT_EXPIRES_IN=24h                                      # Tempo de expiração do JWT (ex: 1h, 24h)
JWT_ALGORITHM=HS256                                     # Algoritmo JWT (ex: HS256)

# =========================
# E-mail (SMTP)
# =========================
EMAIL_HOST=smtp.mailtrap.io         # Host SMTP para envio de e-mails
EMAIL_PORT=2525                     # Porta SMTP
EMAIL_USER=usuario_smtp             # Usuário SMTP
EMAIL_PASS=senha_smtp               # Senha SMTP
EMAIL_FROM=noreply@doecerto.com     # E-mail remetente padrão